const getAllUsers = async () => {
    const response = await fetch(
        "https://jsonplaceholder.typicode.com/users"
    );

    const users = await response.json();

    return users.map(user => ({
        name: user.name,
        email: user.email
    }));
};

getAllUsers().then(console.log);

